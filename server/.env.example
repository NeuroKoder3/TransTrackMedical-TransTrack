# --- Server ---
NODE_ENV=development
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
LOG_LEVEL=info
TRUST_PROXY=false

# --- Database ---
# Either DATABASE_URL or the discrete PG* variables.
DATABASE_URL=postgres://transtrack:transtrack@localhost:5432/transtrack
PGSSL=disable
# Connection pool tuning
PG_POOL_MAX=20
PG_IDLE_TIMEOUT_MS=30000

# --- Auth ---
# Local password auth + JWT-bearer sessions
JWT_SECRET=change-me-32-bytes-minimum-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
JWT_ISSUER=transtrack
JWT_AUDIENCE=transtrack-api
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=2592000

# MFA
MFA_ISSUER_LABEL=TransTrack
MFA_REQUIRED_FOR_ROLES=admin,coordinator,physician,regulator

# Account lockout
LOCKOUT_THRESHOLD=5
LOCKOUT_WINDOW_MINUTES=15
LOCKOUT_DURATION_MINUTES=30

# Password policy
PASSWORD_MIN_LENGTH=12
PASSWORD_HISTORY_COUNT=10

# --- SAML 2.0 (optional) ---
# Leave blank to disable SAML. If set, hospital IdPs (ADFS, Okta, Azure AD,
# PingFederate, Shibboleth) can SSO into the API. Roles are mapped from the
# IdP attribute set in SAML_ROLE_ATTRIBUTE.
SAML_ENABLED=false
SAML_ENTRY_POINT=
SAML_ISSUER=urn:transtrack:sp
SAML_CALLBACK_URL=https://api.example.com/auth/saml/callback
SAML_IDP_CERT=
SAML_ROLE_ATTRIBUTE=urn:oid:1.3.6.1.4.1.5923.1.1.1.7
SAML_EMAIL_ATTRIBUTE=urn:oid:0.9.2342.19200300.100.1.3
SAML_NAME_ATTRIBUTE=urn:oid:2.16.840.1.113730.3.1.241

# --- OIDC (optional) ---
# For Epic, Cerner, Azure AD, Auth0, Keycloak, etc.
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://api.example.com/auth/oidc/callback
OIDC_SCOPES=openid profile email
OIDC_ROLE_CLAIM=transtrack_role

# --- HL7 v2 MLLP listener ---
HL7_MLLP_ENABLED=true
HL7_MLLP_HOST=0.0.0.0
HL7_MLLP_PORT=2575
# TLS is required by hospital interface engines in production. Provide PEM-encoded
# files; if both are blank the listener runs in plaintext (DEV ONLY).
HL7_MLLP_TLS_CERT_FILE=
HL7_MLLP_TLS_KEY_FILE=
HL7_MLLP_TLS_CA_FILE=
HL7_MLLP_TLS_REQUIRE_CLIENT_CERT=true
# Optional pre-shared org for sending applications (mapped from MSH-3 by default).
HL7_DEFAULT_ORG_ID=

# --- FHIR R4 server ---
FHIR_BASE_URL=http://localhost:8080/fhir
FHIR_REQUIRE_AUTH=true

# --- SIEM forwarding (audit) ---
SIEM_ENABLED=false
SIEM_ENDPOINT=
SIEM_TOKEN=
