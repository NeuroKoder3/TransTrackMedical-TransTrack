{
  "name": "@transtrack/server",
  "version": "0.1.0",
  "description": "TransTrack API server: REST + FHIR R4 + MLLP/TLS HL7 v2 listener backed by PostgreSQL",
  "private": true,
  "license": "MIT",
  "main": "src/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20.10"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "migrate": "node src/db/migrate.js up",
    "migrate:down": "node src/db/migrate.js down",
    "migrate:status": "node src/db/migrate.js status",
    "test": "vitest run --config vitest.config.mjs --reporter=verbose",
    "test:watch": "vitest --config vitest.config.mjs",
    "test:integration": "vitest run --config vitest.integration.config.mjs",
    "test:mirth": "cross-env INTEGRATION_MIRTH=1 vitest run --config vitest.integration.config.mjs test/integration/mirth.test.mjs",
    "lint": "eslint src test --max-warnings=0"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/sensible": "^6.0.2",
    "@node-saml/node-saml": "^5.0.0",
    "argon2": "^0.41.1",
    "fastify": "^5.8.5",
    "openid-client": "^5.6.5",
    "otplib": "^12.0.1",
    "pg": "^8.13.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "qrcode": "^1.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "vitest": "^4.1.5",
    "eslint": "^9.13.0"
  }
}
