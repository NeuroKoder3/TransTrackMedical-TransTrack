; TransTrack npm configuration.
;
; Silences install-time noise that is not actionable for this project:
;   - `fund` banners from individual packages
;   - `audit` summary on every install (we run `npm audit` explicitly in CI)
;   - deprecation spam from deep transitive deps owned by electron-builder,
;     @electron/asar, electron-updater and prebuild-install, which we cannot
;     control until those upstream packages publish newer majors.
;
; If you are debugging a dependency problem, temporarily unset these or run
; `npm ci --loglevel=verbose`.

fund=false
audit=false
loglevel=notice
